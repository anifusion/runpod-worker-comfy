# =============================================================================
# Container runtime (src/start.sh, src/rp_handler.py)
# =============================================================================
# Local dev: echo "true" to run ComfyUI + handler with RunPod API on 0.0.0.0 (see docker-compose.yml)
SERVE_API_LOCALLY=false

# ComfyUI queue polling (defaults in code: 250 ms, 500 retries)
COMFY_POLLING_INTERVAL_MS=250
COMFY_POLLING_MAX_RETRIES=500

# RunPod: clean state after each job (https://docs.runpod.io/docs/handler-additional-controls#refresh-worker)
REFRESH_WORKER=false

# Where ComfyUI writes images (default /comfyui/output)
COMFY_OUTPUT_PATH=/comfyui/output

# =============================================================================
# S3 upload (required for Anifusion + most production Comfy endpoints)
# =============================================================================
# Anifusion (character sheet) calls RunPod with only `input.workflow` + `webhook` — no s3Config.
# rp_handler uses runpod.serverless.utils.rp_upload.upload_image(), which calls get_boto_client()
# with NO per-job credentials — only these env vars (see RunPod rp_upload.py).
# Without them, outputs fall back to local paths / base64 and Anifusion cannot fetch results.

# If set (non-empty), uploads via RunPod helpers instead of returning base64
BUCKET_ENDPOINT_URL=
# Required when BUCKET_ENDPOINT_URL is set (S3-compatible access key).
BUCKET_ACCESS_KEY_ID=
BUCKET_SECRET_ACCESS_KEY=

# =============================================================================
# Docker build (--build-arg) / image build scripts
# Defaults match Dockerfile; only needed when customizing `docker build`.
# =============================================================================
WITH_CHARACTER_SHEET_NODES=true
COMFYUI_MV_ADAPTER_REF=v1.0.2
COMFYUI_IMPACT_PACK_REF=8.9
MODEL_TYPE=character-sheet
HUGGINGFACE_ACCESS_TOKEN=
